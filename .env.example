# ─────────────────────────────────────────────────────────────
# أم النور للأدوات المنزلية — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────
# Get your connection string from MongoDB Atlas or local MongoDB
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/om-alnour?retryWrites=true&w=majority"

# ── NextAuth ─────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# The canonical URL of your deployed site
NEXTAUTH_URL="http://localhost:3000"

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Default Admin ────────────────────────────────────────────
# Used by the seed script to create the first admin account
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# ── WhatsApp ─────────────────────────────────────────────────
# Default WhatsApp number (can also be changed from admin settings)
NEXT_PUBLIC_WHATSAPP_NUMBER="+201012506517"

# ── File Upload ──────────────────────────────────────────────
# Maximum upload size in bytes (default: 5MB)
NEXT_PUBLIC_MAX_UPLOAD_SIZE="5242880"

# Upload directory relative to /public
UPLOAD_DIR="uploads"
